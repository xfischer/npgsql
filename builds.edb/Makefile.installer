include redux/common/Makefile.common

# Environment variables

export PKG_STAGING_PATH :=$(PWD)/inst

# Files and directories to be excluded from source archive
ARCHIVE_EXCLUDES:=--exclude=builds.edb** --exclude=*.log*

export PRE_BUILD_STEPS=createSourceArchive 
export BUILD_COMPONENTS=build-dotnet60
export POST_BUILD_STEPS=copy-samples createBuildArchive

# Build .NET6
build-dotnet60:

	cmd /c "pkg\\installer\\build-dotnet6.bat $(DOTNET_SOURCE_PATH) $(NET60_FRAMEWORK) Release AnyCPU NET6.0 $(DOTNET_STAGING_PATH)"

# Build .NET5
build-dotnet50:

	cmd /c "pkg\\installer\\build-dotnet5.bat $(DOTNET_SOURCE_PATH) $(NET50_FRAMEWORK) Release AnyCPU NET5.0 $(DOTNET_STAGING_PATH)"

# Build .NET 461
build-dotnet461:

	cmd /c "pkg\\installer\\build.bat $(DOTNET_SOURCE_PATH) $(NET45_FRAMEWORK) Release AnyCPU NET461 $(DOTNET_STAGING_PATH)"

# Build .NET 451
build-dotnet451:

	# Clone edbas repo
	cd /c/; \
		rm -rf $(DOTNET_451_SOURCE_PATH); \
		git clone $(GIT_REPO_PATH)/edb-dotnet $(DOTNET_451_SOURCE_PATH); \
		cd $(DOTNET_451_SOURCE_PATH); \
		git checkout "$(DOTNET_451_TAG)"; \
		cd -

	cmd /c "pkg\\installer\\build_legacy.bat $(DOTNET_451_SOURCE_PATH) $(NET45_FRAMEWORK) Release AnyCPU NET45 $(DOTNET_STAGING_PATH) $(DOTNET_SOURCE_PATH)"


copy-samples:

	mkdir -p $(DOTNET_STAGING_PATH)/samples
	cp -rp $(SRC_DIR)/samples/SAMPLE_TEST.cs $(DOTNET_STAGING_PATH)/samples

# Install .NET
install: edbclean get-commit $(PRE_BUILD_STEPS) $(BUILD_COMPONENTS) $(POST_BUILD_STEPS)

