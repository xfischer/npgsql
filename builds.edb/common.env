# Clone redux repo to get redux-main.env

if [ -d redux ];
then
	pushd redux
	git pull
	popd
else
	git clone git://github/redux-core redux
fi

source redux/common/redux-main.env

export SRC_DIR=$PWD/..

export EDB_VERSION_DOTNET=$(cat $SRC_DIR/npgsql-6/CommonAssemblyInfo.cs | grep AssemblyVersion | cut -f2 -d"\"")
export EDB_BUILDNUM_DOTNET=${EDB_BUILDNUM_DOTNET:-1}

export REMOTE_HOST="buildfarm@$STORE_NAME"

