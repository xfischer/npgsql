git clone https://${TOKEN}@github.com/EnterpriseDB/redux-core redux

source redux/common/redux-main.env

export SRC_DIR=$PWD/..

export EDB_VERSION_DOTNET=$(cat $SRC_DIR/npgsql-8/CommonAssemblyInfo.cs | grep AssemblyVersion | cut -f2 -d"\"")
export EDB_BUILDNUM_DOTNET=${EDB_BUILDNUM_DOTNET:-1}

export REMOTE_HOST="buildfarm@$STORE_NAME"

