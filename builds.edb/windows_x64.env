# Remote host and location to get packages

source common.env

export DOTNET_SOURCE_PATH=${DOTNET_SOURCE_PATH:-C:\\\\CON-DNET}

export DOTNET_STAGING_PATH=${DOTNET_STAGING_PATH:-$DOTNET_SOURCE_PATH\\\\builds.edb\\\\inst}

export NET45_FRAMEWORK=4.5

export PACKAGE_LIST="pgBuild64 BitRock" 

export REMOTE_PATH="/opt/local/Windows64"

if [[ $REMOTE_HOST == *"redux-store-test"* ]]
then
	export REMOTE_HOST="centos@redux-store"
fi

InstallBuildDependencies
