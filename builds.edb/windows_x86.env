# Remote host and location to get packages

source common.env

export NET45_FRAMEWORK=4.6
export NET50_FRAMEWORK=5.0

export PACKAGE_LIST="VS2017/pgBuild64 BitRock"

export TARGET_ARCH="x86"

export REMOTE_PATH="Windows64"

if [[ $REMOTE_HOST == *"redux-store-test"* ]]
then
	export REMOTE_HOST="buildfarm@redux-store"
fi

InstallBuildDependencies
