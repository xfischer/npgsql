3:20:6c:61:73:74:0d:0a:45:4e:44:3b:0d:0a:0d:0a:2d:2d:20:4c:6f:61:64:20:66:69:65:6c:64:20:64:65:66:69:6e:69:74:69:6f:6e:73:20:66:6f:72:20:28:66:72:65:65:2d:73:74:61:6e:64:69:6e:67:29:20:63:6f:6d:70:6f:73:69:74:65:20:74:79:70:65:73:0d:0a:53:45:4c:45:43:54:20:74:79:70:2e:6f:69:64:2c:20:61:74:74:2e:61:74:74:6e:61:6d:65:2c:20:61:74:74:2e:61:74:74:74:79:70:69:64:0d:0a:46:52:4f:4d:20:70:67:5f:74:79:70:65:20:41:53:20:74:79:70:0d:0a:4a:4f:49:4e:20:70:67:5f:6e:61:6d:65:73:70:61:63:65:20:41:53:20:6e:73:20:4f:4e:20:28:6e:73:2e:6f:69:64:20:3d:20:74:79:70:2e:74:79:70:6e:61:6d:65:73:70:61:63:65:29:0d:0a:4a:4f:49:4e:20:70:67:5f:63:6c:61:73:73:20:41:53:20:63:6c:73:20:4f:4e:20:28:63:6c:73:2e:6f:69:64:20:3d:20:74:79:70:2e:74:79:70:72:65:6c:69:64:29:0d:0a:4a:4f:49:4e:20:70:67:5f:61:74:74:72:69:62:75:74:65:20:41:53:20:61:74:74:20:4f:4e:20:28:61:74:74:2e:61:74:74:72:65:6c:69:64:20:3d:20:74:79:70:2e:74:79:70:72:65:6c:69:64:29:0d:0a:57:48:45:52:45:0d:0a:20:20:28:74:79:70:2e:74:79:70:74:79:70:65:20:3d:20:27:63:27:20:41:4e:44:20:63:6c:73:2e:72:65:6c:6b:69:6e:64:3d:27:63:27:29:20:41:4e:44:0d:0a:20:20:61:74:74:6e:75:6d:20:3e:20:30:20:41:4e:44:20:20:20:20:20:2d:2d:20:44:6f:6e:27:74:20:6c:6f:61:64:20:73:79:73:74:65:6d:20:61:74:74:72:69:62:75:74:65:73:0d:0a:20:20:4e:4f:54:20:61:74:74:69:73:64:72:6f:70:70:65:64:0d:0a:4f:52:44:45:52:20:42:59:20:74:79:70:2e:6f:69:64:2c:20:61:74:74:2e:61:74:74:6e:75:6d:3b:0d:0a:0d:0a:2d:2d:20:4c:6f:61:64:20:65:6e:75:6d:20:66:69:65:6c:64:73:0d:0a:53:45:4c:45:43:54:20:70:67:5f:74:79:70:65:2e:6f:69:64:2c:20:65:6e:75:6d:6c:61:62:65:6c:0d:0a:46:52:4f:4d:20:70:67:5f:65:6e:75:6d:0d:0a:4a:4f:49:4e:20:70:67:5f:74:79:70:65:20:4f:4e:20:70:67:5f:74:79:70:65:2e:6f:69:64:3d:65:6e:75:6d:74:79:70:69:64:0d:0a:4f:52:44:45:52:20:42:59:20:6f:69:64:2c:20:65:6e:75:6d:73:6f:72:74:6f:72:64:65:72:3b:0d:0a:00" value=""/>
