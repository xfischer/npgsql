<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Authors>EnterpriseDB Team, Xavier Fischer, Zahid Khan, Moazzum Ali, Npgsql Contributors</Authors>
    <Description>GeoJSON plugin for EDB Postgres Advanced Server, allowing mapping of PostGIS geometry types to GeoJSON types.</Description>
	<PackageTags>npgsql;epas;advanced server;edb;enterprisedb;postgresql;postgres;postgis;geojson;spatial;ado;ado.net;database;sql</PackageTags>
    <TargetFrameworks>net472;net48;net481;netstandard2.0;net6.0;net7.0</TargetFrameworks>
    <TargetFramework Condition="'$(DeveloperBuild)' == 'True'">net7.0</TargetFramework>
	<AssemblyName>EnterpriseDB.EDBClient.GeoJSON</AssemblyName>
	<Title>EDB .NET Connector - GeoJSON</Title>
	<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="GeoJSON.Net" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Npgsql/Npgsql.csproj" />
    <ProjectReference Include="../Npgsql.SourceGenerators/Npgsql.SourceGenerators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
</ItemGroup>
</Project>
