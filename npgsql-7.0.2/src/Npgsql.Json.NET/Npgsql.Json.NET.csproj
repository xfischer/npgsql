<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Authors>Shay Rojansky</Authors>
    <Description>Json.NET plugin for EDB, allowing transparent serialization/deserialization of JSON objects directly to and from the database.</Description>
    <PackageTags>npgsql;postgresql;json;postgres;ado;ado.net;database;sql</PackageTags>
    <TargetFrameworks>net471;net472;net48;net481;netstandard2.0</TargetFrameworks>
    <TargetFramework Condition="'$(DeveloperBuild)' == 'True'">net7.0</TargetFramework>
	<AssemblyName>EnterpriseDB.EDBClient.Json.NET</AssemblyName>
	<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Npgsql\Npgsql.csproj" />
  </ItemGroup>
</Project>
