<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>EnterpriseDB.EDBClient.EntityFrameworkCore.PostgreSQL.NetTopologySuite</AssemblyName>
    <RootNamespace>EnterpriseDB.EDBClient.EntityFrameworkCore.PostgreSQL.NetTopologySuite</RootNamespace>
    <TargetFramework>net8.0</TargetFramework>
    <TargetFramework Condition="'$(DeveloperBuild)' == 'True'">net8.0</TargetFramework>

    <Authors>EnterpriseDB Team, Xavier Fischer, Zahid Khan, Moazzum Ali, Shay Rojansky</Authors>
    <Description>NetTopologySuite PostGIS spatial support plugin for PostgreSQL/EDB .NET Connector Entity Framework Core provider.</Description>
    <PackageTags>epas;advanced server;edb;enterprisedb;postgresql;postgres;Entity Framework Core;entity-framework-core;ef;efcore;orm;sql;spatial;postgis;nts</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Npgsql.NetTopologySuite\Npgsql.NetTopologySuite.csproj" />
    <ProjectReference Include="..\EFCore.PG\EFCore.PG.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="NetTopologySuite" />
    <Using Include="NetTopologySuite.Geometries" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Shared\*.cs" />
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
