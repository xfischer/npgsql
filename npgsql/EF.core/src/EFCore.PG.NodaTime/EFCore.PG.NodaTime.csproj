<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>EnterpriseDB.EDBClient.EntityFrameworkCore.PostgreSQL.NodaTime</AssemblyName>
    <RootNamespace>EnterpriseDB.EDBClient.EntityFrameworkCore.PostgreSQL.NodaTime</RootNamespace>
    <TargetFramework>net8.0</TargetFramework>
    <TargetFramework Condition="'$(DeveloperBuild)' == 'True'">net8.0</TargetFramework>

    <Authors>EnterpriseDB Team, Xavier Fischer, Zahid Khan, Moazzum Ali, Shay Rojansky</Authors>
    <Description>NodaTime support plugin for PostgreSQL/EDB .NET Connector Entity Framework Core provider.</Description>
    <PackageTags>epas;advanced server;edb;enterprisedb;postgresql;postgres;Entity Framework Core;entity-framework-core;ef;efcore;orm;sql;nodatime;date;time</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Npgsql.NodaTime\Npgsql.NodaTime.csproj" />
    <ProjectReference Include="..\EFCore.PG\EFCore.PG.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="NodaTime" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Shared\*.cs" />
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="build\**\*">
      <Pack>True</Pack>
      <PackagePath>build</PackagePath>
    </None>
  </ItemGroup>

</Project>
