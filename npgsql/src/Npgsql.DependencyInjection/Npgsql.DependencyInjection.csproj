<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Authors>EnterpriseDB Team, Xavier Fischer, Zahid Khan, Moazzum Ali, Npgsql Contributors</Authors>
	<!-- DbDataSource was introduced to .NET in net7.0. Before that EDB has its own built-in copy. -->
        <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
	<PackageTags>npgsql;epas;advanced server;edb;enterprisedb;postgresql;postgres;ado;ado.net;database;sql;di;dependency injection</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
	<AssemblyName>EnterpriseDB.EDBClient.DependencyInjection</AssemblyName>
	<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
	</PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\Npgsql\Npgsql.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
        <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="All" />
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\" />
    </ItemGroup>
</Project>
